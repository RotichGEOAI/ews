# =========================================================================
# North Rift GeoAI + Agentic EWS — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# See CREDENTIALS_AND_ACCESS_REQUIRED.pdf for full details on each item.
# =========================================================================

# ---- Copernicus Data Space Ecosystem (Sentinel-1/2, GLO-30 DEM) ----
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
COPERNICUS_DEM_BBOX=34.74,-0.108,35.44,0.563   # Nandi bbox, extend for North Rift

# ---- Earth Genome — Earth Index ----
EARTH_INDEX_APP_ACCOUNT_EMAIL=
EARTH_INDEX_API_KEY=                # confirm current auth model with Earth Genome
EARTH_INDEX_SOURCE_COOP_TOKEN=      # if Source Cooperative bucket requires auth

# ---- NASA Earthdata (MODIS via LP DAAC / GES DISC, IMERG) ----
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# ---- Google Earth Engine (optional alternate path for MODIS/Sentinel) ----
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_SERVICE_ACCOUNT_KEY_PATH=       # path to service-account JSON key

# ---- NASA POWER ----
# No key required — public API. Included for completeness.

# ---- CHIRPS / TAMSAT ----
# No key required for standard public endpoints.

# ---- ICPAC ----
ICPAC_API_KEY=                      # if using ICPAC's data portal API / partner access

# ---- TAHMO (in-situ weather stations) ----
TAHMO_API_USERNAME=
TAHMO_API_PASSWORD=

# ---- Kenya WRA WRIS (Water Resources Information System) ----
WRA_WRIS_API_KEY=
WRA_WRIS_CLIENT_ID=

# ---- Water Point Data Exchange (WPDx) ----
WPDX_API_KEY=

# ---- ACLED (conflict event data) ----
ACLED_API_KEY=
ACLED_EMAIL=

# ---- Messaging: WhatsApp Business Cloud API (Meta) ----
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# ---- Messaging: Twilio (alternate SMS/WhatsApp path) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Database (PostGIS / TimescaleDB) ----
DATABASE_URL=postgresql://user:password@localhost:5432/north_rift_ews

# ---- General ----
LOG_LEVEL=INFO
ENVIRONMENT=development             # development | staging | production
